{
  "name": "new-black",
  "version": "1.0.0",
  "description": "A comprehensive test suite for both UI and API testing using Playwright, with Allure reporting integration.",
  "scripts": {
    "test": "playwright test",
    "test:ui-mode": "playwright test --ui",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:debug": "playwright test --debug",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results"
  },
  "author": "DARIA SHVETS",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.0",
    "allure-playwright": "^3.6.0",
    "dotenv": "^17.4.1"
  }
}
